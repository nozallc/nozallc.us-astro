<script>
	function openPageSpeed() {
		const inputEl = document.getElementById('domain-input') as HTMLInputElement;
		let domain = inputEl ? inputEl.value.trim() : '';
		
		if (!domain) {
			domain = 'https://example.com';
		} else if (!domain.startsWith('http://') && !domain.startsWith('https://')) {
			domain = 'https://' + domain;
		}
		
		const encodedUrl = encodeURIComponent(domain);
		window.open(`https://pagespeed.web.dev/analysis?url=${encodedUrl}`, '_blank');
	}
	
	// Button click handler
	const pageSpeedBtn = document.getElementById('pagespeed-btn');
	if (pageSpeedBtn) {
		pageSpeedBtn.addEventListener('click', openPageSpeed);
	}
	
	// Allow Enter key to trigger test
	const domainInput = document.getElementById('domain-input') as HTMLInputElement;
	if (domainInput) {
		domainInput.addEventListener('keypress', function(e: KeyboardEvent) {
			if (e.key === 'Enter') {
				openPageSpeed();
			}
		});
	}
</script>
